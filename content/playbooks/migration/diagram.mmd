flowchart TB

    %% ─── Migration trigger ───
    START([Migration Required<br/>legacy system &rarr; new architecture])

    %% ─── First decision ───
    Q1{Can the system<br/>be sliced into independently<br/>migratable pieces?}

    %% ─── Strangler path ───
    subgraph STRANGLER [Strangler Fig &mdash; gradual replacement behind a routing layer]
        direction TB
        S1[Introduce routing layer<br/>callers go through abstraction]
        S2[Migrate one slice at a time<br/>old + new coexist behind layer]
        S3[Each slice cut over progressively<br/>1% &rarr; 10% &rarr; 50% &rarr; 100%]
        S4[Continue until nothing<br/>of legacy remains]

        S1 --> S2 --> S3 --> S4
    end

    %% ─── Branch by Abstraction path ───
    subgraph BRANCH [Branch by Abstraction &mdash; code-level abstraction]
        direction TB
        B1[Introduce wrapping interface<br/>around existing implementation]
        B2[Build new implementation<br/>against same interface]
        B3[Switch interface binding<br/>via feature flag or config]
        B4[Remove old implementation<br/>after watch period]

        B1 --> B2 --> B3 --> B4
    end

    %% ─── Q2: Stateless? ───
    Q2{Is the system<br/>stateless or has<br/>solved state sync?}

    %% ─── Blue-Green path ───
    subgraph BLUEGREEN [Blue-Green &mdash; parallel deploy, traffic switch]
        direction TB
        BG1[Deploy new alongside old<br/>both reachable but not active]
        BG2[Smoke test new<br/>against production-like traffic]
        BG3[Switch traffic at gateway<br/>old retained as fallback]
        BG4[Remove old<br/>after watch period]

        BG1 --> BG2 --> BG3 --> BG4
    end

    %% ─── Q3: Validation possible? ───
    Q3{Can behavioural<br/>equivalence be<br/>verified empirically?}

    %% ─── Parallel Run path ───
    subgraph PARALLEL [Parallel Run &mdash; both systems with same input, compared]
        direction TB
        P1[Both systems receive<br/>same production input]
        P2[Outputs compared on<br/>every transaction]
        P3[Differences logged<br/>and triaged]
        P4[Cutover declared<br/>when outputs match]

        P1 --> P2 --> P3 --> P4
    end

    %% ─── Q4: Last resort ───
    Q4{Is parallel operation<br/>cost prohibitive AND<br/>full validation pre-cutover possible?}

    %% ─── Big Bang path ───
    subgraph BIGBANG [Big-Bang Cutover &mdash; high risk, last resort]
        direction TB
        BB1[Comprehensive pre-cutover validation<br/>characterisation tests, traffic replay]
        BB2[Cutover at scheduled time<br/>tested rollback path ready]
        BB3[Watch period at full traffic<br/>rollback executable for N hours]
        BB4[Decommission only after<br/>extended stable period]

        BB1 --> BB2 --> BB3 --> BB4
    end

    %% ─── Reconsider node ───
    RECON[Reconsider migration scope<br/>or invest in slicing first]

    %% ─── Common discipline applies to all paths ───
    subgraph DISCIPLINE [Discipline Applied to Every Strategy]
        direction TB
        D1[Characterisation tests<br/>before reimplementation]
        D2[Data migration discipline<br/>dual-write / replication / backfill]
        D3[Rollback path tested<br/>before cutover begins]
        D4[Decommissioning planned<br/>with date, owner, criteria]

        D1 --> D2 --> D3 --> D4
    end

    %% ─── Outcome ───
    DONE([Migration Complete<br/>legacy actually removed])

    %% ─── Decision flow ───
    START --> Q1
    Q1 -->|yes - sliceable| STRANGLER
    Q1 -->|no - tightly coupled at code level| BRANCH
    Q1 -->|no - tightly coupled at system level| Q2

    Q2 -->|yes| BLUEGREEN
    Q2 -->|no| Q3

    Q3 -->|yes - same-input comparison feasible| PARALLEL
    Q3 -->|no| Q4

    Q4 -->|yes - both conditions met| BIGBANG
    Q4 -->|no - one or both conditions unmet| RECON

    %% ─── All paths converge through discipline to completion ───
    S4  --> DISCIPLINE
    B4  --> DISCIPLINE
    BG4 --> DISCIPLINE
    P4  --> DISCIPLINE
    BB4 --> DISCIPLINE

    DISCIPLINE --> DONE

